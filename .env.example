# ----- Serveur -----
PORT=3000
NODE_ENV=development

# ----- MongoDB Atlas -----
# Chaîne de connexion du cluster Atlas (Database > Connect > Drivers).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
DB_NAME=ambiance

# ----- Authentification -----
# Clé d'administration des endpoints de gestion (DELETE /devices, POST/PUT /locations).
ADMIN_API_KEY=change-me-admin-key
JWT_SECRET=change-me-jwt-secret

# ----- Bridge Phyphox -----
# Clé x-api-key d'un device (affichée par `npm run seed`). Le seed synchronise
DEVICE_API_KEY=dev_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Lieu ciblé par la collecte (slug d'un lieu existant).
LOCATION_SLUG=cafeteria-roger-gaudry
# URL d'accès distant de Phyphox (menu ⋮ → Autoriser l'accès à distance). Port 8080 par défaut.
PHYPHOX_URL=http://<ip-du-telephone>
# Nom du buffer sonore lu (dB selon l'expérience Phyphox).
PHYPHOX_BUFFER=dB
