# ----- Serveur -----
PORT=3000
NODE_ENV=development

# ----- MongoDB Atlas -----
# Chaîne de connexion du cluster Atlas (Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ambiance?retryWrites=true&w=majority
DB_NAME=ambiance

# ----- Authentification -----
# Clé d'administration utilisée pour les endpoints de gestion (DELETE /devices, POST/PUT /locations).
ADMIN_API_KEY=change-me-admin-key

# Secret pour la signature des tokens JWT (authentification utilisateur, Phase 2)
JWT_SECRET=change-me-jwt-secret

# ----- Limites -----
RATE_LIMIT_PER_MIN=130
MAX_PER_PAGE=200
