{
  "name": "ambiance-collecte-server",
  "version": "1.0.0",
  "description": "Serveur Express + MongoDB Atlas pour la collecte environnementale (ambiance des lieux) — Phase 1, IFT3225.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && node dist/index.js",
    "dev": "npm run build && node --watch dist/index.js",
    "seed": "npm run build && node scripts/seed.js",
    "bridge": "node bridge/bridge.js"
  },
  "keywords": [
    "express",
    "mongodb",
    "phyphox",
    "ift3225",
    "ambiance"
  ],
  "author": "Équipe IFT3225",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.3.0",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
